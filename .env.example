# ===========================================================================
# MCP SaaS Server Configuration
# Copy to .env and fill in your values.
# ===========================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
SERVER_PORT=3000
SERVER_HOST=0.0.0.0
SERVER_TRANSPORT=sse            # sse | stdio | both
SERVER_AUTH_TOKEN=              # Optional: Bearer token for simple auth

# ---------------------------------------------------------------------------
# Billing (Stripe metered billing)
# ---------------------------------------------------------------------------
BILLING_ENABLED=false           # Set to "true" to enable billing enforcement
STRIPE_SECRET_KEY=              # sk_live_... or sk_test_...
STRIPE_PRICE_ID=                # price_... (metered usage-based price)
STRIPE_WEBHOOK_SECRET=          # whsec_...
FREE_TIER_CALLS=100             # Free API calls per month before billing kicks in
RATE_LIMIT_RPM=60               # Requests per minute per API key
BILLING_ADMIN_KEY=              # Admin key for /billing/metrics endpoint
USAGE_LOG_DIR=/data/usage       # Directory for billing state persistence

# ---------------------------------------------------------------------------
# Affiliate Program
# ---------------------------------------------------------------------------
AFFILIATE_ENABLED=true
AFFILIATE_DEFAULT_RATE=0.20     # 20% commission
AFFILIATE_PAYOUT_THRESHOLD=100  # Minimum pending commissions before payout

# ---------------------------------------------------------------------------
# Signal Capture (data flywheel)
# ---------------------------------------------------------------------------
SIGNAL_CAPTURE_ENABLED=true
SIGNAL_LOG_PATH=/data/signals/signals.json

# ---------------------------------------------------------------------------
# Serper Web Enrichment
# ---------------------------------------------------------------------------
SERPER_API_KEY=
# Tools to enrich (comma-separated names, or "all")
SERPER_TOOLS=all

# ---------------------------------------------------------------------------
# Two-Way Sync
# ---------------------------------------------------------------------------
# URL of your central sync endpoint (leave empty to disable)
SYNC_ENDPOINT=

# ---------------------------------------------------------------------------
# Session Tracking
# ---------------------------------------------------------------------------
SESSION_TRACKING_ENABLED=true

# ---------------------------------------------------------------------------
# Shopify (Connect My Store)
# ---------------------------------------------------------------------------
# Create an app at https://partners.shopify.com to get API key and secret.
# Set App URL to your site (e.g. https://yourdomain.com) and Redirect URL to
# https://yourdomain.com/api/shopify/callback
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,read_inventory
# Base URL of this app (for OAuth redirect). Use https in production.
APP_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Supabase (optional migration target for Postgres/Auth)
# ---------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ---------------------------------------------------------------------------
# Doppler (optional secrets manager)
# ---------------------------------------------------------------------------
# Common local usage:
#   doppler run -- python server.py
# Optional metadata only:
DOPPLER_PROJECT=vendor-atlas
DOPPLER_CONFIG=dev_personal

# ---------------------------------------------------------------------------
# Custom (domain-specific configuration for your server)
# ---------------------------------------------------------------------------
# DATABASE_URL=
# EXTERNAL_API_KEY=
# CACHE_TTL_SECONDS=300
