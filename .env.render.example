# Render deployment environment for Vendor Atlas
# Copy these keys into Render Environment Variables or into a private .env.render file locally.

# ---------------------------------------------------------------------------
# Core server
# ---------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_TRANSPORT=sse
SESSION_SECRET=replace-with-a-long-random-secret
APP_BASE_URL=https://your-render-service.onrender.com

# ---------------------------------------------------------------------------
# Supabase / Postgres
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:replace-with-db-password@db.mjqqmgdiydjcdvlbjjvk.supabase.co:5432/postgres
SUPABASE_URL=https://mjqqmgdiydjcdvlbjjvk.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# ---------------------------------------------------------------------------
# Shopify
# ---------------------------------------------------------------------------
SHOPIFY_API_KEY=replace-with-shopify-api-key
SHOPIFY_API_SECRET=replace-with-shopify-api-secret
SHOPIFY_SCOPES=read_products,read_inventory

# ---------------------------------------------------------------------------
# Search / enrichment
# ---------------------------------------------------------------------------
SERPER_API_KEY=replace-with-serper-api-key

# ---------------------------------------------------------------------------
# Billing / optional
# ---------------------------------------------------------------------------
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
BILLING_ADMIN_KEY=

# ---------------------------------------------------------------------------
# Render/runtime helpers
# ---------------------------------------------------------------------------
RENDER=true
PYTHONUNBUFFERED=1
